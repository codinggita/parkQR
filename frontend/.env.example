# =============================================================
# ParkSmart AI - Firebase Environment Variables
# =============================================================
# Copy this file to .env and fill in your Firebase project values.
#
# How to find these values:
#   1. Go to https://console.firebase.google.com
#   2. Select your project (smart-parking-ai-227ed)
#   3. Click the gear icon (⚙️) → Project settings
#   4. Scroll down to "Your apps" → Select your web app
#   5. Copy the config values from the firebaseConfig object
#
# IMPORTANT: All Vite env vars MUST start with VITE_ to be
# exposed to client-side code via import.meta.env
# =============================================================

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
